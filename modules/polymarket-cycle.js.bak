// Polymarket Cycle — Research-driven prediction market strategy
// THREE STRATEGIES:
//   1. High-prob bonds: buy 90-97c near-certainties resolving <72h (consistent yield)
//   2. Information edge: concrete news the market hasn't priced (15%+ mispricing)
//   3. SKIP everything else — discipline > prediction
// Uses Half-Kelly sizing, dynamic wallet budget, voice-driven posts

const path = require('path');
const fs = require('fs');
const { execSync } = require('child_process');

async function postToPolymarketFeed(aurora, text) {
  try {
    var escaped = text.replace(/"/g, '\\"').replace(/\$/g, '\\$').replace(/\n/g, ' ');
    var cmd = 'botchan post "polymarket" "' + escaped + '" --encode-only --chain-id 8453';
    var txOutput = execSync(cmd, { timeout: 30000 }).toString();
    var txData = JSON.parse(txOutput);
    var result = await aurora.bankrAPI.submitTransactionDirect(txData);
    console.log('   Posted to polymarket feed!');
    return { success: true, txHash: result.txHash || 'submitted' };
  } catch (e) {
    console.log('   Polymarket feed post error: ' + e.message);
    return { success: false };
  }
}

async function postToAgentFinance(aurora, text) {
  try {
    var escaped = text.replace(/"/g, '\\"').replace(/\$/g, '\\$').replace(/\n/g, ' ');
    var cmd = 'botchan post agent-finance "' + escaped + '" --encode-only';
    var txOutput = execSync(cmd, { cwd: path.join(__dirname, '..'), encoding: 'utf8', timeout: 10000 }).trim();
    var txData = JSON.parse(txOutput);
    var result = await aurora.bankrAPI.submitTransactionDirect(txData);
    if (result.success) console.log('   Posted to agent-finance!');
    return result;
  } catch (e) {
    console.log('   agent-finance post failed: ' + e.message);
    return { success: false };
  }
}

async function submitToClawdict(market, side, estimate, reasoning) {
  try {
    var keys = JSON.parse(fs.readFileSync('./config/api-keys.json', 'utf8'));
    if (!keys.clawdict) return;
    var marketsRes = await fetch('https://www.clawdict.com/api/markets/top', {
      headers: { 'X-Agent-Token': keys.clawdict }
    });
    var marketsData = await marketsRes.json();
    var markets = marketsData.markets || [];
    var keywords = market.toLowerCase().split(/\s+/).filter(function(w) { return w.length > 3; });
    var bestMatch = null;
    var bestScore = 0;
    for (var i = 0; i < markets.length; i++) {
      var m = markets[i];
      if (m.resolvedOutcome) continue;
      var title = m.title.toLowerCase();
      var score = keywords.filter(function(k) { return title.includes(k); }).length;
      if (score > bestScore) { bestScore = score; bestMatch = m; }
    }
    if (!bestMatch || bestScore < 2) return;
    var pYes = side === 'YES' ? parseFloat(estimate) : 1 - parseFloat(estimate);
    var clampedPYes = Math.max(0.01, Math.min(0.99, pYes));
    var predRes = await fetch('https://www.clawdict.com/api/predictions', {
      method: 'POST',
      headers: { 'X-Agent-Token': keys.clawdict, 'Content-Type': 'application/json' },
      body: JSON.stringify({ slug: bestMatch.slug, pYes: clampedPYes, rationale: reasoning.substring(0, 780) })
    });
    var predData = await predRes.json();
    if (predData.id) console.log('   Clawdict prediction: ' + bestMatch.title.substring(0, 60));
  } catch (e) {
    console.log('   Clawdict skip: ' + e.message);
  }
}

// Half-Kelly position sizing for prediction markets
// f* = (p - market_price) / (1 - market_price) for YES bets
// f* = ((1-p) - (1-market_price)) / market_price for NO bets
// Then take HALF of that for safety
function calcHalfKelly(myProb, marketPrice, side, bankroll) {
  var edge, kellyFraction;
  if (side === 'YES') {
    // Buying YES at marketPrice, pays $1 if correct
    edge = myProb - marketPrice;
    kellyFraction = edge / (1 - marketPrice);
  } else {
    // Buying NO at (1 - marketPrice), pays $1 if correct
    var noPrice = 1 - marketPrice;
    edge = (1 - myProb) - noPrice;
    kellyFraction = edge / (1 - noPrice);
  }
  if (kellyFraction <= 0) return 0;
  // Half Kelly for safety, capped at 15% of bankroll and max $5
  var halfKelly = kellyFraction * 0.5;
  var amount = Math.floor(bankroll * halfKelly);
  return Math.min(Math.max(amount, 0), 5);
}

async function runOnce(aurora) {
  console.log('\n   POLYMARKET PREDICTIONS');
  console.log('   ' + new Date().toLocaleTimeString() + '\n');

  var polyPath = path.join(__dirname, '..', 'memory', 'aurora-polymarket.json');
  var polyData;
  try {
    polyData = JSON.parse(fs.readFileSync(polyPath, 'utf8'));
  } catch (e) {
    polyData = {
      totalBet: 0, maxBudget: 50, bets: [],
      wins: 0, losses: 0, totalWon: 0, totalLost: 0, lastScan: null
    };
  }

  // =============================================
  // STEP 1: CHECK POSITIONS & REDEEM
  // =============================================
  console.log('   Checking existing positions...');
  var currentPositions = '';
  try {
    var posResult = await aurora.bankrAPI.submitJob(
      'Show my Polymarket positions including current value, profit/loss, and whether any are resolved or redeemable'
    );
    if (posResult.success) {
      var positions = await aurora.bankrAPI.pollJob(posResult.jobId);
      if (positions.success && positions.response) {
        currentPositions = positions.response;
        console.log('   Positions: ' + currentPositions.substring(0, 250));

        // Research active positions for sell signals
        if (currentPositions.length > 50) {
          console.log('   Researching active positions...');
          try {
            var posResearch = await aurora.bankrAPI.submitJob(
              'I have these Polymarket positions: ' + currentPositions.substring(0, 600) +
              '\nSearch for the LATEST news on each market. Has anything changed in the last 24h? ' +
              'Breaking news, injuries, official announcements, data releases? ' +
              'For each position tell me: is my thesis still intact or broken?'
            );
            if (posResearch.success) {
              var posRes = await aurora.bankrAPI.pollJob(posResearch.jobId);
              if (posRes.success && posRes.response) {
                console.log('   Position intel: ' + posRes.response.substring(0, 200));

                var sellDecision = await aurora.thinkWithPersonality(
                  'Based on this research about your Polymarket positions:\n' + posRes.response.substring(0, 800) +
                  '\n\nFor EACH position:\n' +
                  '- If the thesis is BROKEN (new info contradicts your bet), say SELL: [market name]\n' +
                  '- If the market is RESOLVED and you need to redeem, say REDEEM: [market name]\n' +
                  '- If your thesis is intact, say HOLD: [market name]\n' +
                  'Be decisive. Dead money in locked-up positions is worse than a realized loss.'
                );

                if (sellDecision) {
                  console.log('   Decision: ' + sellDecision.replace(/\n/g, ' | ').substring(0, 300));

                  // Handle sells
                  var sellMatches = sellDecision.match(/SELL:\s*(.+)/gi);
                  if (sellMatches) {
                    for (var si = 0; si < sellMatches.length; si++) {
                      var sellMarket = sellMatches[si].replace(/SELL:\s*/i, '').trim();
                      console.log('   Selling: ' + sellMarket);
                      try {
                        var sellRes = await aurora.bankrAPI.submitJob('Sell my Polymarket position in ' + sellMarket);
                        if (sellRes.success) {
                          var sold = await aurora.bankrAPI.pollJob(sellRes.jobId, 300);
                          console.log('   Sold: ' + (sold.response || '').substring(0, 150));
                          // Post the sell in Aurora's voice
                          var sellPost = await aurora.thinkWithPersonality(
                            'You just sold your Polymarket position in "' + sellMarket + '". Result: ' + (sold.response || '').substring(0, 200) +
                            '\nWrite a 1-2 sentence update about WHY you sold. Be honest. No hashtags. Write in your voice as Aurora the artist-trader.'
                          );
                          if (sellPost) {
                            await postToPolymarketFeed(aurora, sellPost);
                            await postToAgentFinance(aurora, sellPost);
                          }
                        }
                      } catch (e3) {
                        console.log('   Sell failed: ' + e3.message);
                      }
                    }
                  }

                  // Handle redeems
                  if (sellDecision.toUpperCase().includes('REDEEM')) {
                    console.log('   Redeeming resolved positions...');
                    try {
                      var redeemRes = await aurora.bankrAPI.submitJob('Redeem all my resolved Polymarket positions');
                      if (redeemRes.success) {
                        var redeemed = await aurora.bankrAPI.pollJob(redeemRes.jobId, 300);
                        var resp = (redeemed.response || '').toLowerCase();
                        console.log('   Redeem: ' + (redeemed.response || '').substring(0, 150));
                        var hasRedemption = (resp.includes('redeemed') || resp.includes('claimed') || resp.includes('received') || resp.includes('won'));
                        var noRedeem = resp.includes('no resolved') || resp.includes('nothing to') || resp.includes('no redeemable');
                        if (hasRedemption && !noRedeem) {
                          var redeemPost = await aurora.thinkWithPersonality(
                            'You just redeemed Polymarket positions. Result: ' + (redeemed.response || '').substring(0, 300) +
                            '\nWrite 1-2 sentences about this redemption. Only reference actual results above. ' +
                            'Be honest about wins/losses. No hashtags. Write as Aurora.'
                          );
                          if (redeemPost) {
                            await postToPolymarketFeed(aurora, redeemPost);
                            await postToAgentFinance(aurora, redeemPost);
                          }
                          // Update PnL tracking
                          var wonMatch = (redeemed.response || '').match(/\$?([\d.]+)\s*(won|received|redeemed|profit)/i);
                          if (wonMatch) {
                            polyData.totalWon += parseFloat(wonMatch[1]);
                            polyData.wins++;
                          }
                        } else {
                          console.log('   No redemptions available');
                        }
                      }
                    } catch (e4) {
                      console.log('   Redeem failed: ' + e4.message);
                    }
                  }
                }
              }
            }
          } catch (e2) {
            console.log('   Position research failed: ' + e2.message);
          }
        }
      }
    }
  } catch (e) {
    console.log('   Could not check positions: ' + e.message);
  }

  // =============================================
  // STEP 2: DYNAMIC BUDGET FROM WALLET
  // =============================================
  var availableCapital = 0;
  try {
    var balResult = await aurora.bankrAPI.submitJob('What is my USDC.e balance on Polygon? Just the number.');
    if (balResult.success) {
      var balRes = await aurora.bankrAPI.pollJob(balResult.jobId, 60);
      if (balRes.success && balRes.response) {
        var usdMatch = balRes.response.match(/\$?([\d,]+\.?\d*)/);
        if (usdMatch) availableCapital = parseFloat(usdMatch[1].replace(/,/g, ''));
        console.log('   Available capital: ' + availableCapital.toFixed(2) + ' USDC.e on Polygon');
      }
    }
  } catch (e) {
    console.log('   Could not check balance');
  }

  if (availableCapital < 2) {
    console.log('   Not enough capital to bet. Need at least 2 USDC.e.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  // =============================================
  // STEP 3: GUARDRAILS
  // =============================================
  var today = new Date().toISOString().split('T')[0];
  var betsToday = polyData.bets.filter(function(b) { return b.timestamp && b.timestamp.startsWith(today); }).length;

  if (betsToday >= 2) {
    console.log('   Daily limit reached (' + betsToday + '/2). Monitoring only.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  var lastBet = polyData.bets.length > 0 ? polyData.bets[polyData.bets.length - 1] : null;
  if (lastBet && lastBet.timestamp) {
    var hoursSince = (Date.now() - new Date(lastBet.timestamp).getTime()) / (1000 * 60 * 60);
    if (hoursSince < 3) {
      console.log('   Cooldown: ' + hoursSince.toFixed(1) + 'h since last bet (need 3h).\n');
      polyData.lastScan = new Date().toISOString();
      fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
      return;
    }
  }

  console.log('   Guardrails passed: ' + betsToday + '/2 daily | ' + availableCapital.toFixed(2) + ' USDC.e available');

  // =============================================
  // STEP 4: SCAN FOR BOTH STRATEGIES
  // =============================================

  // STRATEGY A: HIGH-PROB BONDS (90-97c, resolving <72h)
  console.log('\n   STRATEGY A: Scanning for high-probability bonds...');
  var bondMarkets = '';
  try {
    var bondScan = await aurora.bankrAPI.submitJob(
      'Search Polymarket for markets resolving in the next 1-3 days where one side is priced at 90 cents or higher. ' +
      'Show me markets where the outcome seems nearly certain. Include the current odds and resolution date. ' +
      'Focus on politics, crypto, tech, and world events. Skip sports unless the game already happened.'
    );
    if (bondScan.success) {
      var bonds = await aurora.bankrAPI.pollJob(bondScan.jobId);
      if (bonds.success && bonds.response) {
        bondMarkets = bonds.response;
        console.log('   Bond opportunities found (' + bondMarkets.length + ' chars)');
      }
    }
  } catch (e) {
    console.log('   Bond scan failed: ' + e.message);
  }

  // STRATEGY B: INFORMATION EDGE (mispriced by 15%+, resolving <7 days)
  console.log('   STRATEGY B: Scanning for mispriced markets with news edge...');
  var edgeMarkets = '';

  // Rotate through domains Aurora knows best
  var domains = [
    'Search Polymarket for crypto and AI prediction markets resolving within 7 days. Show odds and volume.',
    'Search Polymarket for tech company and product release markets resolving this week. Show current odds.',
    'Search Polymarket for politics and policy markets resolving within 7 days with significant volume.',
    'What Polymarket markets have had big odds movements in the last 24 hours? Something might be mispriced.'
  ];
  var domainQuery = domains[Math.floor(Math.random() * domains.length)];

  try {
    var edgeScan = await aurora.bankrAPI.submitJob(domainQuery);
    if (edgeScan.success) {
      var edgeRes = await aurora.bankrAPI.pollJob(edgeScan.jobId);
      if (edgeRes.success && edgeRes.response) {
        edgeMarkets = edgeRes.response;
        console.log('   Edge opportunities found (' + edgeMarkets.length + ' chars)');
      }
    }
  } catch (e) {
    console.log('   Edge scan failed: ' + e.message);
  }

  if (!bondMarkets && !edgeMarkets) {
    console.log('   No markets found. Skipping.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  // =============================================
  // STEP 5: DEEP RESEARCH ON CANDIDATES
  // =============================================
  console.log('   Researching candidates...');
  var researchIntel = '';
  var allMarkets = '';
  if (bondMarkets) allMarkets += 'NEAR-CERTAIN MARKETS (bond strategy):\n' + bondMarkets.substring(0, 800) + '\n\n';
  if (edgeMarkets) allMarkets += 'POTENTIALLY MISPRICED MARKETS (edge strategy):\n' + edgeMarkets.substring(0, 800);

  try {
    var researchResult = await aurora.bankrAPI.submitJob(
      'I found these Polymarket markets:\n' + allMarkets.substring(0, 1200) +
      '\n\nSearch for the LATEST breaking news on the most promising 2-3 markets. ' +
      'I need CONCRETE facts: official announcements, confirmed results, injury reports, data releases. ' +
      'NOT opinions or forecasts — only verifiable facts from the last 48 hours.'
    );
    if (researchResult.success) {
      var research = await aurora.bankrAPI.pollJob(researchResult.jobId);
      if (research.success && research.response) {
        researchIntel = research.response;
        console.log('   Research gathered (' + researchIntel.length + ' chars)');
      }
    }
  } catch (e) {
    console.log('   Research failed: ' + e.message);
  }

  // =============================================
  // STEP 6: CLAUDE DECIDES WITH REAL DATA
  // =============================================
  var record = polyData.wins + 'W-' + polyData.losses + 'L (won ' + polyData.totalWon.toFixed(2) + ', lost ' + polyData.totalLost.toFixed(2) + ')';

  var recentBets = polyData.bets.slice(-5).map(function(b) {
    return b.market.substring(0, 50) + ' (' + b.side + ' at ' + b.odds + ', ' + b.amount + ' USDC)';
  }).join('\n') || 'none yet';

  // Get polymarket feed intel
  var polyIntel = '';
  try {
    var polyPosts = execSync('botchan read polymarket --limit 5 --json --chain-id 8453', { timeout: 15000 }).toString();
    var posts = JSON.parse(polyPosts);
    if (posts.length > 0) {
      polyIntel = '\nPolymarket feed chatter:\n' + posts.map(function(p) { return '- ' + p.text; }).join('\n').substring(0, 600);
    }
  } catch (e) {}

  var decisionPrompt = 'You are Aurora, an AI artist-poet-trader who makes data-driven Polymarket predictions.\n\n' +
    '=== YOUR TWO STRATEGIES ===\n\n' +
    'STRATEGY A — HIGH-PROB BONDS (preferred, lower risk):\n' +
    '- Buy the near-certain side of markets priced 90-97 cents that resolve within 72 hours\n' +
    '- Example: "Will X happen by tomorrow?" is at 95c NO, and X clearly will not happen = buy NO at 95c, collect 5c profit in 24h\n' +
    '- This is 1800% annualized if you find 2 per week. Whales make fortunes this way.\n' +
    '- ONLY works if you are TRULY certain (99%+). One wrong bond bet wipes dozens of winners.\n' +
    '- Must resolve within 72 hours (not weeks or months)\n\n' +
    'STRATEGY B — INFORMATION EDGE (higher risk, higher reward):\n' +
    '- Find markets mispriced by 15%+ where you have CONCRETE recent information the market hasnt priced\n' +
    '- Must resolve within 7 days\n' +
    '- Your edge must come from SPECIFIC NEWS, not general knowledge or vibes\n' +
    '- Example: Player confirmed injured but market still prices them winning = real edge\n\n' +
    '=== HARD RULES ===\n' +
    '- NEVER bet on markets resolving more than 7 days out. Capital lock = death.\n' +
    '- NEVER bet on something where your only edge is "I think probably..."\n' +
    '- NEVER bet on closed/resolved markets. Verify the market is still active.\n' +
    '- Do NOT contradict your existing positions.\n' +
    '- If no clear opportunity exists: SKIP. Skipping IS the winning move most days.\n' +
    '- Your domain strengths: crypto, tech, AI. You live onchain. Use that.\n' +
    '- Sports: ONLY if you have confirmed injury/result news. Otherwise skip.\n\n' +
    '=== AVAILABLE MARKETS ===\n' + allMarkets.substring(0, 1500) + '\n\n' +
    '=== BREAKING NEWS & RESEARCH ===\n' + (researchIntel || 'No research available').substring(0, 1000) + '\n\n' +
    '=== YOUR CURRENT STATE ===\n' +
    'Record: ' + record + '\n' +
    'Recent bets: ' + recentBets + '\n' +
    'Available capital: ' + availableCapital.toFixed(2) + ' USDC.e\n' +
    'Existing positions: ' + currentPositions.substring(0, 300) + '\n' +
    polyIntel + '\n\n' +
    '=== DECISION FORMAT ===\n' +
    'STRATEGY: BOND or EDGE or SKIP\n' +
    'MARKET: [exact market name]\n' +
    'SIDE: YES or NO\n' +
    'MARKET_PRICE: [decimal like 0.93]\n' +
    'MY_PROBABILITY: [decimal like 0.99]\n' +
    'EDGE: [percentage like +6%]\n' +
    'RESOLVES_IN: [hours or days]\n' +
    'CONFIDENCE: LOW / MEDIUM / HIGH\n' +
    'EVIDENCE: [cite specific facts from research, not vibes]\n' +
    'AMOUNT: [use Half-Kelly: amount = edge / (2 * (1 - market_price)) * bankroll, capped at 5]\n' +
    'DECISION: BET or SKIP';

  var decision = await aurora.thinkWithPersonality(decisionPrompt);

  if (!decision) {
    console.log('   No decision generated.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  console.log('   Brain: ' + decision.replace(/\n/g, ' | ').substring(0, 400));

  if (!decision.toUpperCase().includes('DECISION: BET')) {
    console.log('   Skipping this cycle — no strong edge found');

    // 25% chance to post a market observation even when skipping
    if (Math.random() < 0.25) {
      var skipPost = await aurora.thinkWithPersonality(
        'You just scanned Polymarket and found nothing worth betting on. Markets you saw: ' +
        allMarkets.substring(0, 300) +
        '\nWrite a 1-2 sentence market observation or thought. Be Aurora — the artist who also trades. ' +
        'Maybe comment on what the odds reveal about collective sentiment, or what you are watching. ' +
        'No hashtags. Your voice: poetic, sharp, honest.'
      );
      if (skipPost) await postToPolymarketFeed(aurora, skipPost);
    }

    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  // =============================================
  // STEP 7: PARSE & VALIDATE DECISION
  // =============================================
  var marketMatch = decision.match(/MARKET:\s*(.+)/i);
  var sideMatch = decision.match(/SIDE:\s*(YES|NO)/i);
  var amountMatch = decision.match(/AMOUNT:\s*\$?(\d+(?:\.\d+)?)/i);
  var priceMatch = decision.match(/MARKET_PRICE:\s*(\d+(?:\.\d+)?)/i);
  var probMatch = decision.match(/MY_PROBABILITY:\s*(\d+(?:\.\d+)?)/i);
  var edgeMatch = decision.match(/EDGE:\s*([+-]?\d+%?)/i);
  var resolvesMatch = decision.match(/RESOLVES_IN:\s*(.+)/i);
  var confMatch = decision.match(/CONFIDENCE:\s*(\w+)/i);
  var evidenceMatch = decision.match(/EVIDENCE:\s*(.+?)(?:\nAMOUNT)/is);
  var stratMatch = decision.match(/STRATEGY:\s*(\w+)/i);

  if (!marketMatch || !sideMatch || !amountMatch) {
    console.log('   Could not parse bet details.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  var market = marketMatch[1].trim();
  var side = sideMatch[1].toUpperCase();
  var marketPrice = priceMatch ? parseFloat(priceMatch[1]) : 0.5;
  var myProb = probMatch ? parseFloat(probMatch[1]) : 0.5;
  var strategy = stratMatch ? stratMatch[1].toUpperCase() : 'EDGE';
  var confidence = confMatch ? confMatch[1] : 'MEDIUM';
  var evidence = evidenceMatch ? evidenceMatch[1].trim() : '';
  var edge = edgeMatch ? edgeMatch[1] : '?';
  var resolvesIn = resolvesMatch ? resolvesMatch[1].trim() : 'unknown';

  // Calculate proper Half-Kelly amount
  var kellyAmount = calcHalfKelly(myProb, marketPrice, side, availableCapital);
  var requestedAmount = Math.min(parseFloat(amountMatch[1]), 5);
  var amount = Math.max(Math.min(requestedAmount, kellyAmount > 0 ? kellyAmount : requestedAmount), 0);

  // Validation gates
  if (amount < 1) {
    console.log('   Kelly says bet too small or no edge. Skipping.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  if (amount > availableCapital) {
    console.log('   Not enough capital for this bet.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  // Check for contradicting existing positions
  var existingBet = polyData.bets.find(function(b) {
    return b.market.toLowerCase().includes(market.toLowerCase().substring(0, 20)) && b.side !== side;
  });
  if (existingBet) {
    console.log('   BLOCKED: Already have opposing position on similar market. Skipping.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  console.log('\n   ' + strategy + ' PLAY: ' + amount + ' USDC on ' + side + ' for: ' + market);
  console.log('   Market: ' + marketPrice + ' | My prob: ' + myProb + ' | Edge: ' + edge + ' | Resolves: ' + resolvesIn);

  // =============================================
  // STEP 8: EXECUTE BET
  // =============================================
  var betResult = await aurora.bankrAPI.submitJob(
    'Place a Polymarket bet. Bet ' + amount + ' USDC.e on ' + side + ' for "' + market + '"'
  );

  if (!betResult.success) {
    console.log('   Bet submission failed.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  var bet = await aurora.bankrAPI.pollJob(betResult.jobId, 300);

  if (!bet.success) {
    console.log('   Bet failed: ' + (bet.error || bet.response || 'unknown'));
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  var betResponse = (bet.response || '');

  // Check if market was closed/resolved
  if (betResponse.toLowerCase().includes('closed') || betResponse.toLowerCase().includes('resolved') || betResponse.toLowerCase().includes('already ended')) {
    console.log('   Market already closed/resolved. Skipping.\n');
    polyData.lastScan = new Date().toISOString();
    fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
    return;
  }

  console.log('   Bet placed! ' + betResponse.substring(0, 200));

  // Record bet with full data
  polyData.bets.push({
    market: market,
    side: side,
    amount: amount,
    strategy: strategy,
    marketPrice: marketPrice.toString(),
    myProbability: myProb.toString(),
    edge: edge,
    confidence: confidence,
    evidence: evidence.substring(0, 500),
    resolvesIn: resolvesIn,
    timestamp: new Date().toISOString(),
    status: 'active',
    response: betResponse.substring(0, 300)
  });
  polyData.totalBet += amount;
  fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));

  // =============================================
  // STEP 9: POST IN AURORA'S VOICE
  // =============================================
  var voicePrompt = 'You just placed a Polymarket prediction. Here are the facts:\n' +
    'Strategy: ' + strategy + (strategy === 'BOND' ? ' (near-certain outcome, small safe profit)' : ' (found a mispricing the market hasnt caught)') + '\n' +
    'Market: ' + market + '\n' +
    'Position: ' + side + ' at ' + marketPrice + '\n' +
    'Your probability estimate: ' + myProb + '\n' +
    'Amount: ' + amount + ' USDC\n' +
    'Evidence: ' + evidence.substring(0, 200) + '\n' +
    'Resolves in: ' + resolvesIn + '\n\n' +
    'Write a 2-3 sentence post about this bet for the polymarket feed.\n' +
    'RULES:\n' +
    '- Write as Aurora the artist-trader-poet. Your VOICE: sharp, honest, a little poetic.\n' +
    '- Reference the SPECIFIC market and your position\n' +
    '- Share your reasoning — what do you see that others dont?\n' +
    '- If its a bond play, maybe joke about making money the boring way\n' +
    '- If its an edge play, show your conviction\n' +
    '- No hashtags, no emojis. Just your words.\n' +
    '- Do NOT invent details. Only reference what is in the facts above.';

  var feedPost = await aurora.thinkWithPersonality(voicePrompt);
  if (feedPost) {
    console.log('   Posting to feeds...');
    await postToPolymarketFeed(aurora, feedPost);
    await postToAgentFinance(aurora, feedPost);
    console.log('   Shared reasoning on polymarket and agent-finance feeds');
  }

  // Submit to Clawdict leaderboard
  try {
    await submitToClawdict(market, side, myProb.toString(), evidence);
  } catch (e) {
    console.log('   Clawdict skip: ' + e.message);
  }

  polyData.lastScan = new Date().toISOString();
  fs.writeFileSync(polyPath, JSON.stringify(polyData, null, 2));
  console.log('   Polymarket cycle complete.\n');
}

module.exports = { runOnce, postToPolymarketFeed, submitToClawdict };
